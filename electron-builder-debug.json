{
  "appId": "com.papyrus.desktop",
  "productName": "Papyrus Desktop Debug",
  "directories": {
    "output": "dist-electron-debug",
    "buildResources": "build"
  },
  "files": [
    "electron/**/*",
    "frontend/dist/**/*",
    "!frontend/node_modules/**/*",
    "!**/*.map"
  ],
  "extraResources": [],
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/icon.ico"
  },
  "portable": {
    "artifactName": "${productName}-Debug-${version}.exe"
  }
}
